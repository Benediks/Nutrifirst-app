# ════════════════════════════════════════════════════════
# NutriFirst Backend - Environment Variables Template
# ════════════════════════════════════════════════════════
# Salin file ini menjadi .env, lalu isi nilai sebenarnya.
# JANGAN commit file .env ke Git (sudah masuk .gitignore).
# ════════════════════════════════════════════════════════

# ─── DATABASE ──────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
# Contoh untuk PostgreSQL 13 lokal:
DATABASE_URL="postgresql://nutrifirst_app:YOUR_DB_PASSWORD@localhost:5432/nutrifirst?schema=public"

# ─── JWT AUTHENTICATION ────────────────────────────────
# Generate string acak 32 karakter, contoh perintah Node:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="ganti-dengan-string-acak-minimal-32-karakter-hex"
JWT_EXPIRES_IN="7d"

# ─── INTEGRATION URLS ──────────────────────────────────
# URL frontend Vite untuk konfigurasi CORS (jangan ada trailing slash)
FRONTEND_URL="http://localhost:5173"

# URL AI Service FastAPI.
# PENTING: gunakan 127.0.0.1 (BUKAN localhost) untuk menghindari
# bug IPv6 resolution di Node.js v18+ saat fetch ke FastAPI.
AI_SERVICE_URL="http://127.0.0.1:8000"

# ─── SERVER ────────────────────────────────────────────
PORT=5000

# Mode aplikasi: "development" untuk lokal, "production" untuk deploy.
# Memengaruhi cookie security (secure, sameSite) dan logging.
NODE_ENV="development"
